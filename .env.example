# CONFIGURACIÓN DE CONEXIÓN PARA ROYALMANTENIMIENTO
# Copia este archivo con el nombre '.env' y rellena con tus datos reales.

# 1. URL DE CONEXIÓN A LA BASE DE DATOS
# --- Ejemplo para SQLite (base de datos local en archivo) ---
# DATABASE_URL=sqlite:///taller.db

# --- Ejemplo para PostgreSQL (nube/Heroku) ---
# DATABASE_URL=postgresql://usuario:contraseña@servidor.com:5432/nombre_bd

# --- Ejemplo para Microsoft SQL Server (servidor del trabajo / local) ---
# Usa el driver pymssql provisto en requirements.txt:
# DATABASE_URL=mssql+pymssql://usuario:contraseña@servidor_ip/nombre_bd
DATABASE_URL=mssql+pymssql://analista_cif:Royal2025@localhost/RoyalCIF

# 2. SEGURIDAD
# Clave secreta para la sesión y cifrado de Flask (puedes generar una cadena aleatoria larga)
SECRET_KEY=cambiar-por-una-clave-secreta-muy-larga-y-segura

# 3. INTEGRACIÓN SAMSARA (OPCIONAL)
# Token de la API de Samsara para sincronización de tractos y remolques en tiempo real
SAMSARA_API_TOKEN=tu_token_de_samsara_aqui

# 4. CONFIGURACIÓN DEL SERVIDOR
PORT=5000
FLASK_ENV=production
